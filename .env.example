# Supabase (server-side only — service key must never reach the browser)
SUPABASE_URL=https://twddavxodczywjshedqk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Our tables live in a dedicated schema (isolated from other apps in this DB)
SUPABASE_DB_SCHEMA=attendance
# Postgres connection string for the local ingestion loader (Dashboard → Settings → Database)
SUPABASE_DB_URL=

# Email dispatch
RESEND_API_KEY=
MAIL_FROM="Attendance Verification <no-reply@example.com>"

# App
PUBLIC_SITE_URL=https://your-site.netlify.app

# TL-link encryption (Fernet). Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep it secret and OUT of the database; without it TL link generation is disabled.
TOKEN_ENC_KEY=
